{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "allowJs": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@eq-alla/data": [
        "packages/data/src/index.ts"
      ],
      "@eq-alla/data/*": [
        "packages/data/src/*"
      ],
      "@eq-alla/ui": [
        "packages/ui/src/index.ts"
      ],
      "@eq-alla/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
