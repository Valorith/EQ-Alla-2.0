{
  "name": "eq-alla-2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @eq-alla/web",
    "build": "npm run build -w @eq-alla/web",
    "start": "npm run start -w @eq-alla/web",
    "serve": "npm run build && npm run start",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f web caddy",
    "sync:npc-model-assets": "node scripts/sync-npc-model-assets.mjs",
    "sync:npc-model-assets:ai": "node scripts/upscale-npc-model-assets-ai.mjs",
    "typecheck": "npm run typecheck -w @eq-alla/data && npm run typecheck -w @eq-alla/ui && npm run typecheck -w @eq-alla/web",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "supports-color": "^10.2.2"
  }
}
