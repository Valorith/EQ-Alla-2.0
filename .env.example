# Required for all deployments
EQ_USE_MOCK_DATA=false
EQ_SITE_NAME=EQ Alla 2.0
EQ_SITE_URL=https://eqalla.example.com

# Only needed when a self-hosted reverse proxy like Caddy uses it
EQ_SITE_HOST=eqalla.example.com

# Leave this at 3000 for local/self-hosted setups.
# Railway injects PORT automatically.
PORT=3000

# Preferred application database variables.
# On Railway, MYSQLHOST / MYSQLPORT / MYSQLDATABASE / MYSQLUSER / MYSQLPASSWORD
# or DATABASE_URL / MYSQL_URL also work automatically.
EQ_DB_HOST=127.0.0.1
EQ_DB_PORT=3306
EQ_DB_NAME=peq
EQ_DB_USER=app_user
EQ_DB_PASSWORD=change-me

# Optional. REDIS_URL also works automatically on Railway.
EQ_REDIS_URL=redis://redis:6379
